describe("canManageUsers", () => {
  it("welfare_member 可以管理使用者", () => {
    expect(canManageUsers("welfare_member")).toBe(true)
  })

  it("employee 不能管理使用者", () => {
    expect(canManageUsers("employee")).toBe(false)
  })

  it("hr 不能管理使用者", () => {
    expect(canManageUsers("hr")).toBe(false)
  })
})
