    expect(canRegister("registering")).toBe(true)
  })

  it("waitlist 可以加入候補", () => {
    expect(canRegister("waitlist")).toBe(true)
  })

  it("not_open 不能報名", () => {
    expect(canRegister("not_open")).toBe(false)
  })

  it("closed 不能報名", () => {
    expect(canRegister("closed")).toBe(false)
  })

